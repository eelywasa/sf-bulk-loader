# -----------------------------------------------------------------------
# Salesforce Bulk Loader — Environment Variables
#
# This is the single .env file for the entire project.
#
# Docker:     docker-compose.yml passes this file to the backend container
#             via `env_file: .env`. Run from the project root.
#
# Local dev:  The backend (config.py) searches for ../.env then .env,
#             so `cd backend && uvicorn app.main:app --reload` picks this
#             file up automatically.
#
# Setup:
#   cp .env.example .env   (from project root)
#
# NEVER commit .env — it contains secrets.
# -----------------------------------------------------------------------

# -----------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------

# Distribution profile. Controls auth mode, transport mode, and storage mode.
# desktop | self_hosted | aws_hosted  (default: self_hosted)
APP_DISTRIBUTION=self_hosted

# Runtime environment. Controls CORS policy and log formatting.
# development | production
APP_ENV=production

# Log verbosity. DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Fernet encryption key for sensitive fields (Salesforce private keys, tokens).
# Generate a new key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Must be a 32-byte URL-safe base64-encoded string.
ENCRYPTION_KEY=

# -----------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------

# SQLite (default — quick start, single-node, or desktop installs).
# Four slashes = absolute path /data/db/... which is where Docker Compose
# bind-mounts the host ./data/db directory. Three slashes would be relative
# to WORKDIR (/app) and data would be lost on container restart.
DATABASE_URL=sqlite+aiosqlite:////data/db/bulk_loader.db

# PostgreSQL (recommended for multi-user or production-style self-hosted installs).
# Required for aws_hosted profile. Any standard connection string works, including
# RDS endpoints (add ?ssl=require for RDS with SSL enforcement).
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/bulk_loader

# -----------------------------------------------------------------------
# Salesforce API defaults
# -----------------------------------------------------------------------

# Salesforce REST API version to use for all calls.
SF_API_VERSION=v62.0

# Initial polling interval (seconds) after a Bulk API job is submitted.
SF_POLL_INTERVAL_INITIAL=5

# Maximum polling interval (seconds) after exponential backoff.
SF_POLL_INTERVAL_MAX=30

# If a job remains InProgress longer than this many minutes, log a warning
# and continue polling (Salesforce may impose its own limits).
SF_JOB_TIMEOUT_MINUTES=30

# -----------------------------------------------------------------------
# CSV partitioning
# -----------------------------------------------------------------------

# Default records per Bulk API job partition (configurable per step).
DEFAULT_PARTITION_SIZE=10000

# Hard upper limit. Salesforce enforces a 150 MB per upload constraint.
MAX_PARTITION_SIZE=100000000

# -----------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------

# Secret key used to sign session JWTs. Required. Generate a strong random value:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# JWT token lifetime in minutes (default: 60).
# JWT_EXPIRY_MINUTES=60

# Bootstrap admin credentials — required on first boot when no users exist.
# Ignored after the first user has been created.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# -----------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------
# JSON array of allowed origins. For Docker deployments all traffic is
# proxied through nginx (same-origin) so CORS is not required — leave
# as the default. Set to your public URL only if clients access the
# backend API directly (i.e. not through the nginx proxy).
CORS_ORIGINS=["http://localhost"]

# -----------------------------------------------------------------------
# TLS / HTTPS
# -----------------------------------------------------------------------
# HTTPS is optional for self-hosted deployments and is enabled via the
# docker-compose.https.yml overlay (see README). The default quick-start
# runs HTTP-only on port 80.
#
# When using the HTTPS overlay, place certificate files at ./certs/:
#   certs/cert.pem  — full certificate chain (leaf + any intermediates)
#   certs/key.pem   — unencrypted private key
#
# Self-signed cert (for internal/dev use):
#   mkdir certs
#   openssl req -x509 -newkey rsa:4096 -keyout certs/key.pem -out certs/cert.pem \
#     -sha256 -days 825 -nodes -subj "/CN=bulkloader.internal" \
#     -addext "subjectAltName=DNS:bulkloader.internal,IP:x.x.x.x"
# (SAN extension required — modern browsers reject CN-only certs)

# -----------------------------------------------------------------------
# Volume paths (must match Docker Compose volume mounts)
# -----------------------------------------------------------------------

# Source CSV files. Mounted read-only in the backend container.
INPUT_DIR=/data/input

# Success/error result CSVs written here after each job completes.
OUTPUT_DIR=/data/output
