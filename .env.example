# -----------------------------------------------------------------------
# Salesforce Bulk Loader — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# -----------------------------------------------------------------------

# Application
APP_ENV=development          # development | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# Encryption key for storing Salesforce credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Database
# SQLite path is relative to the container working directory.
# In Docker, /data/db is a persistent named volume.
DATABASE_URL=sqlite+aiosqlite:///data/db/bulk_loader.db

# Salesforce API
SF_API_VERSION=v62.0
SF_POLL_INTERVAL_INITIAL=5   # seconds; starting poll interval for job status
SF_POLL_INTERVAL_MAX=30      # seconds; maximum poll interval after backoff
SF_JOB_TIMEOUT_MINUTES=30    # warn (but keep polling) if a job exceeds this

# CSV partitioning
DEFAULT_PARTITION_SIZE=10000   # records per Bulk API job
MAX_PARTITION_SIZE=100000000   # hard upper limit (Salesforce: 150 MB per upload)

# Volume paths (match Docker Compose volume mounts)
INPUT_DIR=/data/input          # mounted read-only in Docker
OUTPUT_DIR=/data/output        # success/error result CSVs written here
