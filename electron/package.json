{
  "name": "sf-bulk-loader-desktop",
  "version": "0.1.0",
  "description": "Salesforce Bulk Loader — Desktop",
  "main": "main.js",
  "author": "Matthew Jenkin <mjenkin@salesforce.com>",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:frontend": "cd ../frontend && npm run build:desktop",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.example.sf-bulk-loader",
    "productName": "Salesforce Bulk Loader",
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/sf_bulk_loader",
        "to": "backend/sf_bulk_loader"
      },
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [{ "target": "zip", "arch": ["arm64"] }],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "category": "Development"
    }
  }
}
